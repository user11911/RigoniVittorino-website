# Environment variables for the /it/contatti/ contact form backend (Task 2).
# See IMPLEMENTATION_NOTES.md for full setup steps.
#
# There are two separate places these actually need to live, because Astro's
# build-time PUBLIC_ vars and Cloudflare Workers' request-time bindings/secrets
# are two different systems:
#   - PUBLIC_* vars: put in a real ".env" file (Vite/Astro reads this at build time).
#   - Everything else: put in a real ".dev.vars" file for local `wrangler dev`,
#     and set via `wrangler secret put <NAME>` (or the Cloudflare dashboard's
#     Workers & Pages > your worker > Settings > Variables) for production.
# Both ".env" and ".dev.vars" are gitignored — never commit real values.

# --- Public (safe to expose client-side; goes in .env) ---

# Cloudflare Turnstile site key (public, embedded in the page's HTML).
# Default below is Cloudflare's own published "always passes" TEST key — safe to
# use for local dev/testing without a real Cloudflare account. Replace with your
# real site key (from the Cloudflare dashboard, Turnstile > add a widget) before
# going live.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Cloudflare Web Analytics site token (public, embedded in the page's HTML beacon
# script). Get one from the Cloudflare dashboard: Analytics & Logs > Web Analytics >
# Add a site > copy the token. Leave unset to run without analytics — this is a
# normal, supported state (the beacon script simply doesn't render), not an error
# path. The beacon also never renders outside a production build (`astro build`),
# so local `npm run dev` traffic is never counted regardless of this value.
PUBLIC_CF_ANALYTICS_TOKEN=

# --- Server-side secrets/config (goes in .dev.vars locally; wrangler secrets/dashboard vars in production) ---

# Turnstile secret key, paired with the site key above. Default is Cloudflare's
# published "always passes" TEST secret (see
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/) —
# always returns success, for local/test use only.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend API key (https://resend.com). Leave unset to run in dry-run mode: emails
# are logged to the console instead of sent — this is the safe local/test path,
# not an error state.
RESEND_API_KEY=

# The "from" address for both automated emails. Must be on a domain verified with
# Resend (adds SPF/DKIM DNS records alongside your existing Google Workspace MX
# records — additive, does not affect existing mailboxes).
CONTACT_FROM_EMAIL=Rigoni Vittorino <no-reply@rigonivittorino.com>

# Where the notification email lands — set this to an existing Google Workspace
# mailbox. Placeholder below; confirm the real address with the site owner before
# production launch (see IMPLEMENTATION_NOTES.md "Known limitations").
CONTACT_RECIPIENT_EMAIL=info@rigonivittorino.com

# Any random secret string, used only to salt the hashed IP stored for rate-
# limiting (never the raw IP). Generate your own for production, e.g.:
#   openssl rand -hex 32
CONTACT_IP_HASH_SALT=change-me-to-a-random-string
