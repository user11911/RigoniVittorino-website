---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import ProductCard from "../../../components/ProductCard.astro";
import { categories } from "../../../data/categories";
import { products } from "../../../data/products";

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { categoria: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const categoryProducts = products.filter((p) => p.category === category.slug);
---

<BaseLayout
  title={category.name}
  description={`${category.description} Scopri i vini ${category.name} di Rigoni Vittorino.`}
>
  <Hero
    image="/images/hero/rigoni-s2-bottiglie.jpg"
    eyebrow="I nostri vini"
    title={category.name}
    subtitle={category.description}
  />

  <section class="section">
    <div class="container">
      <p class="breadcrumb"><a href="/vini">I nostri vini</a> / {category.name}</p>
      <div class="grid-products">
        {categoryProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .grid-products {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3);
  }
</style>
