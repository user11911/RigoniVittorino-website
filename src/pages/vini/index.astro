---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { categories } from "../../data/categories";
import { products } from "../../data/products";

const categoryImages: Record<string, string> = Object.fromEntries(
  categories.map((cat) => [
    cat.slug,
    products.find((p) => p.category === cat.slug)!.image,
  ])
);
---

<BaseLayout
  title="I nostri vini"
  description="Scopri tutti i vini Rigoni Vittorino: spumanti, bianchi, rossi, affinati, frizzanti e rosati, passiti."
>
  <Hero
    image="/images/hero/rigoni-s2-bottiglie.jpg"
    eyebrow="Il catalogo"
    title="I nostri vini"
    subtitle="Sei tipologie, un solo territorio: scopri la nostra selezione."
  />

  <section class="section">
    <div class="container grid-categories">
      {categories.map((cat) => (
        <CategoryCard category={cat} image={categoryImages[cat.slug]} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .grid-categories {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-3);
  }
</style>
