---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { categories } from "../../data/categories";

const categoryImages: Record<string, string> = {
  spumanti: "/images/hero/rigoni-s2-bottiglie.jpg",
  bianchi: "/images/hero/cantina-rigoni-filosofia-h.jpg",
  rossi: "/images/hero/rigoni-barique-riflessi-c.jpg",
  affinati: "/images/hero/rigoni-barique-riflessi-c.jpg",
  "frizzanti-e-rosati": "/images/hero/rigoni-s2-bottiglie.jpg",
  passiti: "/images/hero/rigoni-s5-cantina.jpg",
};
---

<BaseLayout
  title="I nostri vini"
  description="Scopri tutti i vini Rigoni Vittorino: spumanti, bianchi, rossi, affinati, frizzanti e rosati, passiti."
>
  <Hero
    image="/images/hero/rigoni-s2-bottiglie.jpg"
    eyebrow="Il catalogo"
    title="I nostri vini"
    subtitle="Sei tipologie, un solo territorio: scopri la nostra selezione."
  />

  <section class="section">
    <div class="container grid-categories">
      {categories.map((cat) => (
        <CategoryCard category={cat} image={categoryImages[cat.slug]} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .grid-categories {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-3);
  }
</style>
