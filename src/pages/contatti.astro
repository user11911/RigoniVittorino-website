---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contatti"
  description="Contatta la cantina Rigoni Vittorino a Gorgo al Monticano (TV): indirizzo, telefono ed email."
>
  <section class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Contatti</p>
        <h1>Vieni a trovarci</h1>
        <p>
          Per informazioni su prodotti, visite in cantina o collaborazioni
          commerciali, contattaci direttamente: saremo lieti di risponderti.
        </p>
        <dl class="contact-details">
          <div>
            <dt>Indirizzo</dt>
            <dd>
              Via Malintrada 17<br />
              31040 Gorgo al Monticano (TV), Italia
            </dd>
          </div>
          <div>
            <dt>Telefono</dt>
            <dd><a href="tel:+390422746459">+39 0422.746459</a></dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><a href="mailto:info@rigonivittorino.com">info@rigonivittorino.com</a></dd>
          </div>
        </dl>
        <a
          class="btn btn-outline"
          href="https://www.google.com/maps/search/?api=1&query=Via+Malintrada+17+31040+Gorgo+al+Monticano+TV"
          target="_blank"
          rel="noopener noreferrer"
        >
          Apri in Google Maps
        </a>
      </div>
      <div class="map-placeholder" role="img" aria-label="Mappa indicativa della sede in Via Malintrada 17, Gorgo al Monticano (TV)">
        <p>Mappa: Via Malintrada 17, Gorgo al Monticano (TV)</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .contact-details {
    margin: var(--space-3) 0;
  }

  .contact-details dt {
    font-weight: 600;
    color: var(--color-wine-dark);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .contact-details dd {
    margin: 0 0 var(--space-2);
  }

  .map-placeholder {
    background: var(--color-bg-alt);
    border-radius: 4px;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-3);
  }

  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
