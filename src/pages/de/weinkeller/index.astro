---
export const prerender = true;
import { readFile } from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import localeEquivalents from "../../../data/locale-equivalents.json";

const contentHtml = await readFile(
  path.join(process.cwd(), "src/content/main/de/weinkeller.html"),
  "utf8",
);
---

<BaseLayout
  title="Weinkeller - Rigoni Vittorino"
  ogTitle="Weinkeller"
  bodyClass="singular missing-post-thumbnail"
  lang="de"
  otherLangUrls={localeEquivalents.pages.cantina}
>
  <Fragment set:html={contentHtml} />
</BaseLayout>
