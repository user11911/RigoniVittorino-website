---
export const prerender = true;
import { readFile } from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import localeEquivalents from "../../data/locale-equivalents.json";

const contentHtml = await readFile(
  path.join(process.cwd(), "src/content/main/de/home.html"),
  "utf8",
);
// Same 4 images as /it/ (confirmed language-neutral). Captions confirmed via
// the live WordPress REST API (https://rigonivittorino.com/de/wp-json/wp/v2/pages/1746) —
// see src/pages/en/index.astro for the full method explanation.
const slides = [
  { image: "/wp-content/uploads/2021/01/rigoni-s2-bottiglie.jpg", caption: "Dies ist das Markenzeichen von Vittorino" },
  { image: "/wp-content/uploads/2021/01/rigoni-s3-vigneti.jpg", caption: "Liebe zum Land und zur Familie" },
  { image: "/wp-content/uploads/2021/01/rigoni-s4-famiglia.jpg", caption: "Eine Leidenschaft, an der drei Generationen beteiligt sind" },
  { image: "/wp-content/uploads/2021/01/rigoni-s5-cantina.jpg", caption: "Die beste Technologie, die Tradition umfasst" },
];
---

<BaseLayout
  title="Rigoni Vittorino"
  ogTitle="Home"
  extraStyleFile="home-extra-style.de.css"
  bodyClass="home"
  lang="de"
  otherLangUrls={localeEquivalents.pages.home}
>
  <Hero slides={slides} />
  <Fragment set:html={contentHtml} />
</BaseLayout>
