---
export const prerender = true;
import BaseLayout from "../../../layouts/BaseLayout.astro";
import WineCard from "../../../components/WineCard.astro";
import categories from "../../../data/categories.json";
import wines from "../../../data/wines.json";

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { categoria: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const categoryWines = wines.filter((w) => w.category === category.slug);
---

<BaseLayout title={`${category.title} - Rigoni Vittorino`} ogTitle={category.title}>
  <article class={`page type-page status-publish hentry wines-category-${category.slug}`}>
    <header class="entry-header has-text-align-center header-footer-group">
      <div class="entry-header-inner section-inner medium">
        <h1 class="entry-title">{category.title}</h1>
      </div>
    </header>
    <div class="post-inner">
      <div class="entry-content">
        <div class="wines-row-container">
          <div class={`wine-cat-background ${category.slug}`}>
            <img class="category-logo-ico logo-rigoni-ico ico-color" src={category.categoryLogo} />
            <h1 class="category-title">{category.title}</h1>
          </div>
          <div class="wine-list-container">
            {
              categoryWines.map((wine) => (
                <WineCard
                  slug={wine.slug}
                  title={wine.title}
                  cardImageSrc={wine.cardImageSrc}
                  cardImageSrcset={wine.cardImageSrcset}
                  cardImageWidth={wine.cardImageWidth}
                  cardImageHeight={wine.cardImageHeight}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
