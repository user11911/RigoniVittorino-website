---
// Task 9: /it/news/ (Task 4) is now a compatibility redirect to the shared,
// language-neutral /news/ route (src/pages/news/index.astro). On-demand, not
// prerendered — the same pattern already proven by src/pages/api/contact.ts —
// since Astro.redirect() with a custom status code requires on-demand rendering.
// 301 (permanent): this is a real, permanent URL move for a GET-only
// navigational link, unlike root "/"'s per-visitor 302 country redirect.
export const prerender = false;
return Astro.redirect("/news/", 301);
