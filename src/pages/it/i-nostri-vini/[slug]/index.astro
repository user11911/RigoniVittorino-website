---
export const prerender = true;
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ShareButtons from "../../../../components/ShareButtons.astro";
import wines from "../../../../data/wines.json";

export function getStaticPaths() {
  return wines.map((wine) => ({
    params: { slug: wine.slug },
    props: { wine },
  }));
}

const { wine } = Astro.props;
const pageUrl = `https://rigonivittorino.com/it/i-nostri-vini/${wine.slug}/`;
// Confirmed live: product slugs are identical across it/en/de.
const otherLangUrls = { en: `/en/wines/${wine.slug}/`, de: `/de/wines/${wine.slug}/` };
// Task 11: the "SHOP ONLINE" button (.buy-wine) was removed by explicit user request.
// Per the user's own explicit decision, .specs-row's 6-column grid is intentionally left
// unchanged — the 3 icons below stay in their original position/size in columns 1-3, and
// columns 4-6 are now empty at desktop widths (≥1024px). This is a deliberate, accepted
// outcome, not an oversight — see .claude/TODO.md Task 11 for the full reasoning. Below
// 1024px this row already collapses to a 3-column layout with no such gap.
---

<BaseLayout title={`${wine.title} - Rigoni Vittorino`} ogTitle={wine.title} lang="it" otherLangUrls={otherLangUrls}>
  <article class="wines-template-default single single-wines hentry">
    <div class="wine-container">
      <div class="wine-image">
        <img class="zoooom" src={wine.productImage} alt={wine.title} />
      </div>
      <div class="description">
        <h1>{wine.title}</h1>
        <div class="specs-row">
          <div class={`wine-glass wine-detail ${wine.category}`}>
            <img class="glass-ico-wine" src={wine.glassIcon} />
          </div>
          <div class={`wine-grado wine-detail ${wine.category}`}>
            <p class="contenuto-specs">{wine.servingTempBadge}</p>
          </div>
          <div class={`wine-food-ico wine-detail ${wine.category}`}>
            <img class="glass-ico-wine" src={wine.foodIcon} />
          </div>
        </div>

        <div class="tipologia-row">
          <span class="wine-specs">
            <strong>Tipologia:</strong> <a class="category-link" href={`/it/${wine.category}/`}>{wine.typologyLabel}</a>
          </span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Gradazione:</strong> {wine.gradazione}</span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Coltivazione:</strong> {wine.coltivazione}</span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Vinificazione:</strong> {wine.vinificazione}</span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Resa Media:</strong> {wine.resaMedia}</span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Abbinamenti:</strong> {wine.abbinamenti}</span>
          <hr class="wine-separator" />
          <span class="wine-specs"><strong>Servizio:</strong> {wine.servizio}</span>
        </div>

        <div class="buttons-row">
          <div class="info-wine">
            <a class="scheda-wine" target="_blank" rel="noopener" href={wine.pdfUrl}>
              <button class="hvr-sweep-to-right info-wine-btn">SCHEDA TECNICA</button>
              <button class="arrowBtn"><span class="icon"><i class="fal fa-arrow-right" /></span></button>
            </a>
          </div>
        </div>

        <ShareButtons postId={wine.slug} title={wine.title} url={pageUrl} />
      </div>
    </div>

    <div class="text-wine-container">
      <div class="wine-color-logo">
        <span class=""><img class="v-ico-wine" src={wine.categoryLogo} /></span>
      </div>
      <div class="wine-description">
        <div>
          <span class="wine-description-text">
            {wine.tastingNoteParagraphs.map((p: string) => <p>{p}</p>)}
          </span>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
