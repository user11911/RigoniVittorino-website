---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CategoryCard from "../components/CategoryCard.astro";
import ProductCard from "../components/ProductCard.astro";
import { categories } from "../data/categories";
import { products } from "../data/products";

const categoryImages: Record<string, string> = {
  spumanti: "/images/hero/rigoni-s2-bottiglie.jpg",
  bianchi: "/images/hero/cantina-rigoni-filosofia-h.jpg",
  rossi: "/images/hero/rigoni-barique-riflessi-c.jpg",
  affinati: "/images/hero/rigoni-barique-riflessi-c.jpg",
  "frizzanti-e-rosati": "/images/hero/rigoni-s2-bottiglie.jpg",
  passiti: "/images/hero/rigoni-s5-cantina.jpg",
};

const featured = categories.map(
  (cat) => products.find((p) => p.category === cat.slug)!
);
---

<BaseLayout
  title="Rigoni Vittorino"
  description="Cantina Rigoni Vittorino: vini veneti di famiglia, dalla campagna al bicchiere. Scopri spumanti, bianchi, rossi e passiti."
>
  <Hero
    image="/images/hero/rigoni-s3-vigneti.jpg"
    eyebrow="Dal 1950, tre generazioni di famiglia"
    title="Dalla campagna al bicchiere"
    subtitle="Vini veneti coltivati e vinificati con passione a Gorgo al Monticano, nel cuore della Marca Trevigiana."
    ctaHref="/vini"
    ctaLabel="Scopri i nostri vini"
  />

  <section class="section philosophy">
    <div class="container philosophy-inner">
      <p class="eyebrow">La nostra filosofia</p>
      <h2>Il controllo dell'intera filiera</h2>
      <p>
        Dalla vigna alla bottiglia, seguiamo ogni fase della produzione con
        cura artigianale e tecnologia enologica moderna. Quasi 100 ettari
        vitati tra Malintrada, Cessalto, Chiarano e Motta di Livenza danno
        vita a vini che raccontano il territorio veneto.
      </p>
      <a href="/azienda" class="btn btn-outline">Scopri l'azienda</a>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow">Selezione</p>
      <h2>I nostri vini</h2>
      <div class="grid grid-products">
        {featured.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Categorie</p>
      <h2>Esplora per tipologia</h2>
      <div class="grid grid-categories">
        {categories.map((cat) => (
          <CategoryCard category={cat} image={categoryImages[cat.slug]} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt cantina-teaser">
    <div class="container cantina-teaser-inner">
      <div>
        <p class="eyebrow">La cantina</p>
        <h2>Oltre 3.500 mq dedicati alla qualità</h2>
        <p>
          La nostra cantina unisce tradizione e tecnologia per garantire il
          massimo rispetto delle uve in ogni fase della vinificazione.
        </p>
        <a href="/cantina" class="btn">Scopri la cantina</a>
      </div>
      <img
        src="/images/hero/rigoni-s5-cantina.jpg"
        alt="Interno della cantina Rigoni Vittorino"
        width="560"
        height="380"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .philosophy-inner {
    max-width: 42rem;
    text-align: center;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  .grid-products {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  }

  .grid-categories {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .cantina-teaser-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    align-items: center;
  }

  .cantina-teaser-inner img {
    border-radius: 4px;
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 720px) {
    .cantina-teaser-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
