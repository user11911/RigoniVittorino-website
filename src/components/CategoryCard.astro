---
import type { Category } from "../data/categories";

interface Props {
  category: Category;
  image: string;
}

const { category, image } = Astro.props;
---

<a href={`/vini/${category.slug}`} class="category-card">
  <img src={image} alt="" width="400" height="300" loading="lazy" />
  <div class="category-card-body">
    <h3>{category.name}</h3>
    <p>{category.description}</p>
    <span class="category-cta">Scopri</span>
  </div>
</a>

<style>
  .category-card {
    display: block;
    color: var(--color-wine-dark);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-bg-alt);
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .category-card:hover,
  .category-card:focus-visible {
    box-shadow: 0 10px 24px rgba(57, 0, 17, 0.12);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .category-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .category-card-body {
    padding: var(--space-3);
  }

  .category-card-body p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .category-cta {
    display: inline-block;
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-wine);
  }
</style>
