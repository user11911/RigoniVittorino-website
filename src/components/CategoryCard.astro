---
import type { Category } from "../data/categories";
import { ui, type Locale } from "../i18n/ui";

interface Props {
  category: Category;
  image: string;
  lang?: Locale;
}

const { category, image, lang = "it" } = Astro.props;
---

<a href={`/vini/${category.slug}`} class="category-card">
  <div class="category-card-image">
    <img src={image} alt="" width="637" height="1000" loading="lazy" />
  </div>
  <div class="category-card-body">
    <h3>{category.name}</h3>
    <p>{category.description}</p>
    <span class="category-cta">{ui.discover[lang]}</span>
  </div>
</a>

<style>
  .category-card {
    display: block;
    color: var(--color-wine-dark);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-bg-alt);
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .category-card:hover,
  .category-card:focus-visible {
    box-shadow: 0 10px 24px rgba(57, 0, 17, 0.12);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .category-card-image {
    background: var(--color-bg-alt);
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .category-card-image img {
    height: 90%;
    width: auto;
    object-fit: contain;
  }

  .category-card-body {
    padding: var(--space-3);
  }

  .category-card-body p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .category-cta {
    display: inline-block;
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-wine);
  }
</style>
