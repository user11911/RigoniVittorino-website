---
import { categories } from "../data/categories";

const navLinks = [
  { href: "/azienda", label: "Azienda" },
  { href: "/cantina", label: "Cantina" },
  { href: "/vini", label: "I nostri vini" },
  { href: "/contatti", label: "Contatti" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="Rigoni Vittorino" width="140" height="66" />
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      id="nav-toggle"
    >
      <span class="visually-hidden">Apri il menu</span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Navigazione principale">
      <ul>
        {navLinks.map((link) => (
          <li class:list={{ "has-submenu": link.href === "/vini" }}>
            <a href={link.href}>{link.label}</a>
            {link.href === "/vini" && (
              <ul class="submenu">
                {categories.map((cat) => (
                  <li>
                    <a href={`/vini/${cat.slug}`}>{cat.name}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("primary-nav");
  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("is-open");
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-bg-alt);
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-2);
  }

  .logo img {
    height: 48px;
    width: auto;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle-bar {
    width: 26px;
    height: 2px;
    background: var(--color-wine-dark);
  }

  .primary-nav > ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .primary-nav a {
    color: var(--color-wine-dark);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .primary-nav a:hover,
  .primary-nav a:focus-visible {
    color: var(--color-wine);
  }

  .has-submenu {
    position: relative;
  }

  .submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid var(--color-bg-alt);
    list-style: none;
    margin: 0;
    padding: var(--space-1) 0;
    min-width: 200px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .has-submenu:hover .submenu,
  .has-submenu:focus-within .submenu {
    display: block;
  }

  .submenu a {
    display: block;
    padding: var(--space-1) var(--space-2);
    text-transform: none;
    font-weight: 500;
  }

  @media (max-width: 860px) {
    .nav-toggle {
      display: flex;
    }

    .primary-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid var(--color-bg-alt);
    }

    .primary-nav.is-open {
      display: block;
    }

    .primary-nav > ul {
      flex-direction: column;
      gap: 0;
      padding: var(--space-2) var(--space-3);
    }

    .primary-nav > ul > li {
      border-bottom: 1px solid var(--color-bg-alt);
    }

    .primary-nav a {
      display: block;
      padding: var(--space-2) 0;
    }

    .submenu {
      position: static;
      display: block;
      border: 0;
      box-shadow: none;
      padding-left: var(--space-2);
    }
  }
</style>
