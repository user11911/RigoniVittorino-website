---
import { locales, localeLabels, localePaths, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<ul class="language-switcher" aria-label="Selezione lingua">
  {locales.map((locale) => (
    <li>
      <a
        href={localePaths[locale]}
        aria-current={locale === lang ? "page" : undefined}
      >
        {localeLabels[locale]}
      </a>
    </li>
  ))}
</ul>

<style>
  .language-switcher {
    display: flex;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .language-switcher a {
    color: var(--color-text-muted);
    padding: 0.2rem 0.4rem;
  }

  .language-switcher a:hover,
  .language-switcher a:focus-visible {
    color: var(--color-wine);
    text-decoration: none;
  }

  .language-switcher a[aria-current="page"] {
    color: var(--color-wine-dark);
    text-decoration: underline;
  }
</style>
